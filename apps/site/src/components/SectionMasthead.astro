---
/**
 * Section opener for the Field Journal volumes: mono eyebrow, oversized
 * serif title, one-line lede, and a mono corpus-stats line ("13 posts ·
 * 19 talks · since 2015") computed at build time.
 */
interface Props {
  eyebrow: string;
  title: string;
  lede?: string | undefined;
  /** Pre-formatted stat fragments, joined with a middle dot. */
  stats?: string[] | undefined;
}

const { eyebrow, title, lede, stats } = Astro.props;
---

<header class="masthead">
  <p class="workbench eyebrow">→ {eyebrow}</p>
  <h1 class="masthead-title">{title}</h1>
  {lede && <p class="lede">{lede}</p>}
  {stats && stats.length > 0 && (
    <p class="workbench stats">
      {stats.map((s, i) => (
        <>
          {i > 0 && <span class="sep" aria-hidden="true">·</span>}
          <span>{s}</span>
        </>
      ))}
    </p>
  )}
</header>

<style>
  .masthead {
    padding: var(--space-5) 0 var(--space-4);
    border-bottom: 2px solid var(--green-primary);
    margin-bottom: var(--space-4);
  }
  .eyebrow {
    color: var(--green-primary);
    margin: 0 0 var(--space-2);
  }
  .masthead-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.02;
    margin: 0 0 var(--space-2);
  }
  .lede {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--ink-muted);
    max-width: var(--measure);
    margin: 0 0 var(--space-2);
  }
  .stats {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin: 0;
    color: var(--ink-muted);
  }
  .sep {
    color: var(--orange-accent);
  }
</style>
