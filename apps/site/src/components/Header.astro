---
import type { Locale } from '@lib/i18n';
import { t, localePath } from '@lib/i18n';
import LocaleSwitcher from './LocaleSwitcher.astro';
import Search from './Search.astro';

interface Props {
  locale: Locale;
  /** path within current locale where the alternate translation lives, e.g. "blog/foo" */
  alternatePath?: string | undefined;
  /** if true, the alternate locale has no equivalent of this page */
  alternateMissing?: boolean;
}

const { locale, alternatePath, alternateMissing = false } = Astro.props;
const strings = t(locale);
const homeHref = localePath(locale);

const navItems = [
  { href: localePath(locale, 'writing-talking'), label: strings.nav.writingTalking },
  { href: localePath(locale, 'inspiration'), label: strings.nav.inspiration },
  { href: localePath(locale, 'personal'), label: strings.nav.personal },
  { href: localePath(locale, 'workshop'), label: strings.nav.workshop },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="page-frame header-row">
    <a class="brand" href={homeHref} aria-label={strings.nav.home}>
      <span class="brand-mark">{strings.nav.home}</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const active = currentPath === item.href || currentPath.startsWith(item.href);
            return (
              <li>
                <a href={item.href} class:list={['nav-link', { 'nav-link-active': active }]}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div class="header-end">
      <div class="search-slot"><Search locale={locale} /></div>
      <LocaleSwitcher
        locale={locale}
        alternatePath={alternatePath}
        alternateMissing={alternateMissing}
      />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg-paper);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(140%) blur(6px);
  }
  .header-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "brand controls"
      "nav nav";
    align-items: center;
    justify-content: space-between;
    gap: 0.45rem var(--space-2);
    padding: 0.55rem var(--space-3);
  }
  .brand {
    grid-area: brand;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--ink);
    border: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .brand:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .brand-mark {
    color: var(--green-primary);
    font-weight: 700;
    text-transform: lowercase;
  }
  nav {
    grid-area: nav;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  nav::-webkit-scrollbar {
    display: none;
  }
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(1rem, 4vw, var(--space-3));
    flex-wrap: nowrap;
    width: max-content;
  }
  nav li {
    flex: 0 0 auto;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    border: none;
    padding: 4px 0;
    border-bottom: 1.5px solid transparent;
    white-space: nowrap;
  }
  .nav-link:hover {
    background: transparent;
    color: var(--orange-accent);
    border-bottom-color: var(--orange-accent);
  }
  .nav-link-active {
    color: var(--green-primary);
    border-bottom-color: var(--green-primary);
  }
  .header-end {
    grid-area: controls;
    display: flex;
    gap: var(--space-2);
    align-items: center;
    justify-self: end;
  }
  .search-slot {
    display: none;
  }
  @media (min-width: 768px) {
    .header-row {
      display: flex;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      flex-wrap: wrap;
    }
    nav {
      overflow: visible;
    }
    nav ul {
      flex-wrap: wrap;
      width: auto;
      max-width: none;
      gap: var(--space-3);
    }
    .search-slot {
      display: inline-block;
    }
  }
</style>
