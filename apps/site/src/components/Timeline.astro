---
/**
 * The Field Journal timeline — the shared spine of "writing & talking",
 * "inspiration" and the homepage. One vertical rule, square ledger nodes,
 * mono date stamps in the margin, oversized serif year milestones.
 *
 * Entries are a discriminated union (post | talk | book) so each kind keeps
 * its own anatomy while sharing the spine grammar. Future-dated talks render
 * with an "upcoming" treatment (dashed node, orange stamp), reconciled
 * client-side so a stale static build self-corrects on load.
 */
import type { TimelineEntry } from '@lib/content';
import { postSlug } from '@lib/content';
import { bcp47Locale, languageBadge, localePath, t, type Locale } from '@lib/i18n';

interface Props {
  locale: Locale;
  entries: TimelineEntry[];
  /** Homepage variant: no year milestones, tighter rows, no abstracts/photos. */
  compact?: boolean;
  /** Backlog variant: full anatomy, but undated — no milestones, no date
   *  stamps, hollow "pending" nodes. */
  undated?: boolean;
}

const { locale, entries, compact = false, undated = false } = Astro.props;
const strings = t(locale);

const monthFmt = new Intl.DateTimeFormat(bcp47Locale(locale), { month: 'short' });
function stampMonth(d: Date): string {
  return monthFmt.format(d).replace(/\.$/, '').toUpperCase();
}

const today = new Date();
today.setHours(0, 0, 0, 0);
function isUpcoming(d: Date): boolean {
  const x = new Date(d);
  x.setHours(0, 0, 0, 0);
  return x >= today;
}

/** Rows interleave milestones with entries (skipped in compact mode). A
 *  milestone is a year, except approximate-date entries (books read "long
 *  ago", exact date unknown) which collapse into one undated bucket. */
type GroupKey = number | 'approx';
const groupKey = (e: TimelineEntry): GroupKey =>
  e.kind === 'book' && e.approx ? 'approx' : e.date.getFullYear();

type Row =
  | { row: 'milestone'; key: GroupKey }
  | { row: 'entry'; entry: TimelineEntry };

const rows: Row[] = [];
if (compact || undated) {
  for (const entry of entries) rows.push({ row: 'entry', entry });
} else {
  let current: GroupKey | null = null;
  for (const entry of entries) {
    const key = groupKey(entry);
    if (key !== current) {
      current = key;
      rows.push({ row: 'milestone', key });
    }
    rows.push({ row: 'entry', entry });
  }
}

const KIND_GLYPHS = { post: '✎', talk: '▸', book: '❖', photos: '✧' } as const;

function kindLabel(kind: 'post' | 'talk' | 'book' | 'photos'): string {
  return strings.timeline[kind];
}
---

<ol class:list={['timeline', { 'timeline-compact': compact, 'timeline-undated': undated }]} role="list">
  {rows.map((r) => {
    if (r.row === 'milestone') {
      const ago = r.key === 'approx';
      const label = ago ? strings.timeline.longAgo : String(r.key);
      return (
        <li class="milestone" aria-label={label}>
          <span class:list={['milestone-year', { 'milestone-ago': ago }]}>{label}</span>
        </li>
      );
    }
    const entry = r.entry;
    const upcoming = entry.kind === 'talk' && isUpcoming(entry.date);
    // Approximate-date books carry no exact stamp — the "long time ago"
    // milestone above them is their dateline. Backlog (undated) entries
    // carry none either. Keep an empty cell so the spine node still aligns.
    const approx = undated || (entry.kind === 'book' && entry.approx);
    const stamp = approx ? (
      <p class="stamp" aria-hidden="true"></p>
    ) : (
      <p class="stamp">
        <time datetime={entry.date.toISOString()}>
          <span class="stamp-day">{entry.date.getDate()}</span>
          <span class="stamp-month">{stampMonth(entry.date)}</span>
          {compact && <span class="stamp-year">{entry.date.getFullYear()}</span>}
        </time>
      </p>
    );

    if (entry.kind === 'post') {
      const post = entry.post;
      const href = localePath(locale, `blog/${postSlug(post)}`);
      return (
        <li class="entry entry-post" data-iso={entry.date.toISOString()}>
          {stamp}
          <article class="body">
            <p class="workbench kindline">
              <span class="kind">{KIND_GLYPHS.post} {kindLabel('post')}</span>
              <span class="kind-badge">{languageBadge(post.data.language)}</span>
            </p>
            <h3 class="title"><a href={href}>{post.data.title}</a></h3>
            {!compact && <p class="summary">{post.data.summary}</p>}
          </article>
        </li>
      );
    }

    if (entry.kind === 'talk') {
      const talk = entry.talk;
      const href = localePath(locale, `talks/${talk.slug}`);
      const firstPara = talk.data.abstract.split(/\n\n+/)[0];
      return (
        <li
          class:list={['entry', 'entry-talk', { 'is-upcoming': upcoming }]}
          data-iso={entry.date.toISOString()}
          data-upcomable
        >
          {stamp}
          <article class="body">
            <p class="workbench kindline">
              <span class="kind">{KIND_GLYPHS.talk} {kindLabel('talk')}</span>
              {upcoming && <span class="kind-upcoming" data-upcoming-tag>{strings.timeline.upcoming}</span>}
              <span class="kind-event">
                {talk.data.eventUrl ? (
                  <a href={talk.data.eventUrl} rel="noopener">{talk.data.event}</a>
                ) : (
                  talk.data.event
                )}
              </span>
              {talk.data.language && <span class="kind-badge">{languageBadge(talk.data.language)}</span>}
            </p>
            <h3 class="title"><a href={href}>{talk.data.title}</a></h3>
            {!compact && firstPara && <p class="summary">{firstPara}</p>}
            {!compact && (
              <ul class="links" role="list">
                {talk.data.videoUrl && <li><a href={talk.data.videoUrl} rel="noopener">{strings.labels.video}</a></li>}
                {talk.data.slidesUrl && <li><a href={talk.data.slidesUrl} rel="noopener">{strings.labels.slides}</a></li>}
                {talk.data.repoUrl && <li><a href={talk.data.repoUrl} rel="noopener">{strings.labels.repo}</a></li>}
                <li><a class="more" href={href}>→</a></li>
              </ul>
            )}
            {!compact && talk.data.photos.length > 0 && (
              <ul class="photos" role="list">
                {talk.data.photos.slice(0, 4).map((src) => (
                  <li>
                    <a href={src} target="_blank" rel="noopener">
                      <img src={src} alt="" loading="lazy" />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </article>
        </li>
      );
    }

    if (entry.kind === 'photos') {
      return (
        <li class="entry entry-photos" data-iso={entry.date.toISOString()}>
          {stamp}
          <article class="body">
            <p class="workbench kindline">
              <span class="kind">{KIND_GLYPHS.photos} {kindLabel('photos')}</span>
              {entry.caption && <span class="kind-event">{entry.caption}</span>}
              {entry.location && <span class="kind-badge">{entry.location}</span>}
            </p>
            <ul class="photos photos-grid" role="list">
              {entry.photos.map((src) => (
                <li>
                  <a href={src} target="_blank" rel="noopener">
                    <img src={src} alt="" loading="lazy" />
                  </a>
                </li>
              ))}
            </ul>
          </article>
        </li>
      );
    }

    const book = entry.book;
    const href = localePath(locale, `books/${book.slug}`);
    const stars = book.data.rating
      ? '★'.repeat(book.data.rating) + '☆'.repeat(5 - book.data.rating)
      : null;
    return (
      <li class="entry entry-book" data-iso={entry.date.toISOString()}>
        {stamp}
        <article class="body body-book">
          <a class="cover" href={href} aria-hidden="true" tabindex="-1">
            <img src={book.data.cover} alt="" loading="lazy" />
          </a>
          <div class="book-meta">
            <p class="workbench kindline">
              <span class="kind">{KIND_GLYPHS.book} {kindLabel('book')}</span>
              {stars && (
                <span class="stars" aria-label={`${strings.books.rating}: ${book.data.rating}/5`}>{stars}</span>
              )}
            </p>
            <h3 class="title"><a href={href}>{book.data.title}</a></h3>
            <p class="author">{strings.books.by} {book.data.author}</p>
            {!compact && <p class="summary">{book.data.summary}</p>}
          </div>
        </article>
      </li>
    );
  })}
</ol>

<script>
  // A static build's idea of "today" goes stale between deploys; reclassify
  // future-marked talks on load so yesterday's talk stops glowing.
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  document.querySelectorAll<HTMLElement>('[data-upcomable]').forEach((el) => {
    const iso = el.dataset.iso;
    if (!iso) return;
    const d = new Date(iso);
    d.setHours(0, 0, 0, 0);
    const upcoming = d >= today;
    el.classList.toggle('is-upcoming', upcoming);
    if (!upcoming) el.querySelector('[data-upcoming-tag]')?.remove();
  });
</script>

<style>
  /* ── Spine geometry ─────────────────────────────────────────────
     A grid of [margin stamp | content] with the spine drawn between
     them. Square nodes sit on the spine — everything sharp, nothing
     rounded, to match the printed-workbench identity. */
  .timeline {
    --spine-x: 6.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 0.4rem;
    bottom: 0.4rem;
    left: var(--spine-x);
    width: 1px;
    background: var(--rule);
  }

  /* ── Year milestones — the spine breaks for a big serif numeral ── */
  .milestone {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-4) 0 var(--space-2);
    margin-left: calc(var(--spine-x) - 2.6rem);
  }
  .milestone-year {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--green-primary);
    background: var(--bg-paper);
    padding-right: 0.35rem;
    position: relative;
    z-index: 1;
  }
  /* The undated bucket is a phrase, not a numeral — size it down so it
     reads as a quiet section header rather than a giant year. */
  .milestone-ago {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
  }
  .milestone::after {
    content: '';
    flex: 1 1 auto;
    border-top: 1px dashed var(--rule);
    transform: translateY(-0.45em);
  }

  /* ── Entries ────────────────────────────────────────────────────── */
  .entry {
    position: relative;
    display: grid;
    grid-template-columns: calc(var(--spine-x) - var(--space-2)) minmax(0, 1fr);
    gap: 0 calc(var(--space-3) + var(--space-2));
    padding: var(--space-3) 0;
  }
  /* Square node on the spine. */
  .entry::before {
    content: '';
    position: absolute;
    left: var(--spine-x);
    top: calc(var(--space-3) + 0.5em);
    width: 9px;
    height: 9px;
    transform: translate(-50%, 0) rotate(45deg);
    background: var(--green-primary);
    border: 2px solid var(--bg-paper);
    z-index: 1;
  }
  .entry.is-upcoming::before {
    background: var(--bg-paper);
    border: 2px solid var(--orange-accent);
  }
  /* Backlog: hollow node reads as "open / not yet done". */
  .timeline-undated .entry::before {
    background: var(--bg-paper);
    border: 2px solid var(--green-primary);
  }

  /* ── Margin stamp ───────────────────────────────────────────────── */
  .stamp {
    margin: 0;
    text-align: right;
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.3;
    padding-top: 0.15em;
    user-select: none;
  }
  .stamp time {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .stamp-day {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
  }
  .stamp-month {
    font-size: 0.72rem;
    letter-spacing: 0.07em;
  }
  .stamp-year {
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }
  .is-upcoming .stamp-day,
  .is-upcoming .stamp-month,
  .is-upcoming .stamp-year {
    color: var(--orange-accent);
  }

  /* ── Entry body ─────────────────────────────────────────────────── */
  .kindline {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin: 0 0 0.35rem;
  }
  .kind {
    color: var(--green-primary);
    letter-spacing: 0.05em;
  }
  .kind-upcoming {
    color: var(--orange-accent);
    border: 1px dashed var(--orange-accent);
    padding: 0 0.4rem;
    letter-spacing: 0.06em;
  }
  .kind-event a,
  .kind-event {
    color: var(--ink-muted);
  }
  .kind-event a {
    border-bottom: 1px solid var(--rule);
  }
  .kind-event a:hover {
    background: transparent;
    color: var(--orange-accent);
    border-bottom-color: var(--orange-accent);
  }
  .kind-badge {
    color: var(--ink-muted);
    border: 1px solid var(--rule);
    padding: 0 0.35rem;
    font-size: 0.68rem;
    background: var(--bg-elevated);
  }
  .stars {
    color: var(--orange-accent);
    letter-spacing: 0.08em;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.6vw, 1.55rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.18;
    margin: 0 0 0.35rem;
  }
  .title a {
    border-bottom: none;
    color: inherit;
  }
  .title a:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .summary {
    color: var(--ink-muted);
    margin: 0;
    max-width: var(--measure);
  }
  .author {
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-muted);
    margin: 0 0 0.35rem;
  }

  .links {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .photos {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .photos img {
    height: 96px;
    width: auto;
    object-fit: cover;
    border: 1px solid var(--rule);
    display: block;
  }
  .photos a {
    border: none;
  }
  .photos a:hover {
    background: transparent;
  }
  .photos a:hover img {
    border-color: var(--orange-accent);
  }
  /* Personal moments: photos lead, so they get a full grid, not a strip. */
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-2);
  }
  .photos-grid img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
  }
  @media (max-width: 600px) {
    .photos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Book anatomy: hard-shadow cover beside the meta ───────────── */
  .body-book {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .cover {
    flex: 0 0 auto;
    border: none;
    display: block;
  }
  .cover:hover {
    background: transparent;
  }
  .cover img {
    width: 76px;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    box-shadow: 3px 4px 0 0 var(--rule);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .entry-book:hover .cover img {
    transform: translate(-1px, -1px);
    box-shadow: 5px 6px 0 0 var(--rule);
  }
  .book-meta {
    min-width: 0;
  }

  /* ── Compact (homepage) variant ─────────────────────────────────── */
  .timeline-compact .entry {
    padding: var(--space-2) 0;
  }
  .timeline-compact .title {
    font-size: 1.25rem;
  }
  .timeline-compact .stamp time {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    column-gap: 0.4rem;
  }
  .timeline-compact .cover img {
    width: 52px;
  }

  /* ── Mobile: spine hugs the left edge, stamp moves inline ──────── */
  @media (max-width: 600px) {
    .timeline {
      --spine-x: 0.3rem;
    }
    .entry {
      grid-template-columns: minmax(0, 1fr);
      padding-left: var(--space-3);
    }
    /* The compact (homepage) variant resets padding via the more-specific
       shorthand `.timeline-compact .entry { padding: var(--space-2) 0 }`, which
       wiped out the left gutter above — dropping the date stamp to x=0, right
       under the spine node so the diamond overlapped the day digit. Restore the
       gutter at matching specificity (this rule comes later, so it wins). */
    .timeline-compact .entry {
      padding-left: var(--space-3);
    }
    .entry::before {
      top: calc(var(--space-3) + 0.35em);
    }
    .stamp {
      text-align: left;
      padding-top: 0;
      margin-bottom: 0.3rem;
    }
    .stamp-day {
      font-size: 0.85rem;
    }
    .milestone {
      margin-left: 0;
      padding-left: var(--space-3);
    }
    .milestone-year {
      font-size: 2.2rem;
      padding-left: 0.3rem;
      margin-left: -0.3rem;
    }
    .body-book {
      gap: var(--space-2);
    }
    .cover img {
      width: 60px;
    }
  }
</style>
