---
import type { Locale } from '@lib/i18n';
import { t, htmlLang, ogLocale, otherLocale } from '@lib/i18n';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PhotoLightbox from '@components/PhotoLightbox.astro';
import '@styles/tokens.css';

interface Props {
  locale: Locale;
  title?: string | undefined;
  description?: string | undefined;
  /** sub-path (no locale prefix) of the alternate translation */
  alternatePath?: string | undefined;
  alternateMissing?: boolean;
  /** apply theme-lab inversion (used for /lab/ and /games/ pages) */
  themeLab?: boolean;
  /** when true, robots noindex (drafts, error pages) */
  noindex?: boolean;
  /** path to the page's social card under /og/, defaults to the home card */
  ogImage?: string | undefined;
}

const {
  locale,
  title,
  description,
  alternatePath,
  alternateMissing = false,
  themeLab = false,
  noindex = false,
  ogImage,
} = Astro.props;

const strings = t(locale);
const fullTitle = title ? `${title} — ${strings.site.title}` : strings.site.title;
const meta = description ?? strings.site.tagline;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage ?? `/og/home-${locale}.png`, Astro.site).toString();
---

<!doctype html>
<html lang={htmlLang(locale)} data-pagefind-filter={`language:${locale}`} data-pagefind-meta={`language:${locale}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={meta} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${strings.site.title} (${locale.toUpperCase()})`} href={`/${locale}/rss.xml`} />
    {alternatePath !== undefined && !alternateMissing && (
      <link rel="alternate" hreflang={htmlLang(otherLocale(locale))} href={`/${otherLocale(locale)}/${alternatePath.replace(/^\/+/, '')}/`} />
    )}
    {import.meta.env.PROD && (
      <Fragment>
        <script is:inline async src="https://plausible.io/js/pa-M8AOqaq3j7YY412uq6p9W.js"></script>
        <script is:inline>
          window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
          plausible.init()
        </script>
      </Fragment>
    )}
  </head>
  <body class:list={[{ 'theme-lab': themeLab }]}>
    <Header locale={locale} alternatePath={alternatePath} alternateMissing={alternateMissing} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <PhotoLightbox locale={locale} />
  </body>
</html>
