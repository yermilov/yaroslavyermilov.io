---
import { bcp47Locale, type Locale } from '@lib/i18n';
import { t } from '@lib/i18n';
import BaseLayout from './BaseLayout.astro';
import TranslationPendingBanner from '@components/TranslationPendingBanner.astro';

interface Props {
  locale: Locale;
  title: string;
  description?: string | undefined;
  publishedAt: Date;
  updatedAt?: Date | undefined;
  coverImage?: string | undefined;
  alternatePath?: string | undefined;
  alternateMissing?: boolean;
  /** the original-language post body is being shown as a fallback */
  translationPending?: boolean;
  /** language of the post body that is actually being shown */
  sourceLocale: Locale;
  /** path to the post's social card under /og/ */
  ogImage?: string | undefined;
}

const {
  locale,
  title,
  description,
  publishedAt,
  updatedAt,
  coverImage,
  alternatePath,
  alternateMissing = false,
  translationPending = false,
  sourceLocale,
  ogImage,
} = Astro.props;

const strings = t(locale);
const fmt = new Intl.DateTimeFormat(bcp47Locale(locale), { dateStyle: 'long' });
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  alternatePath={alternatePath}
  alternateMissing={alternateMissing}
  ogImage={ogImage}
>
  <article class="page-frame post" data-pagefind-body>
    <header class="post-header prose-column">
      {translationPending && <TranslationPendingBanner locale={locale} sourceLocale={sourceLocale} />}
      <p class="workbench post-meta">
        <time datetime={publishedAt.toISOString()}>{fmt.format(publishedAt)}</time>
        {updatedAt && (
          <>
            <span aria-hidden="true">·</span>
            <span>{strings.labels.updated}: {fmt.format(updatedAt)}</span>
          </>
        )}
      </p>
      <h1>{title}</h1>
    </header>
    {coverImage && (
      <figure class="post-cover prose-column">
        <img src={coverImage} alt="" loading="eager" />
      </figure>
    )}
    <div class="post-body prose-column">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: var(--space-5) var(--space-3) var(--space-6);
  }
  .post-header {
    margin-bottom: var(--space-4);
  }
  .post-meta {
    margin-bottom: var(--space-2);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .post-cover {
    margin: 0 0 var(--space-4);
  }
  .post-cover img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    border: 1px solid var(--rule);
  }
  .post-body :global(img),
  .post-body :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--rule);
  }
  /* Restore default list bullets/numbers — Tailwind Preflight strips them
     globally and we don't use the typography plugin, so prose lists need
     their own scoped re-enable. */
  .post-body :global(ul) {
    list-style: disc outside;
    padding-inline-start: 1.4rem;
  }
  .post-body :global(ol) {
    list-style: decimal outside;
    padding-inline-start: 1.6rem;
  }
  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }
  .post-body :global(li:last-child) {
    margin-bottom: 0;
  }
  .post-body :global(li > ul),
  .post-body :global(li > ol) {
    margin-top: 0.4rem;
  }
  .post-body :global(li > ul) {
    list-style-type: circle;
  }
  .post-body :global(li > ul ul) {
    list-style-type: square;
  }
</style>
