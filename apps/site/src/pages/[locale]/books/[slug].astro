---
import { LOCALES, t, localePath, bcp47Locale, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getBooks } from '@lib/content';

export async function getStaticPaths() {
  const books = await getBooks();
  return LOCALES.flatMap((locale) =>
    books.map((book) => ({
      params: { locale, slug: book.slug },
      props: { book },
    })),
  );
}

const { book } = Astro.props;
const locale = Astro.params.locale as Locale;
const strings = t(locale);
const { Content } = await book.render();

const hasRating = typeof book.data.rating === 'number';
const rating = book.data.rating ?? 0;
const category = book.data.series || book.data.genre || null;

// The lead stamp: "BACKLOG" for planned books, otherwise the read date —
// "long time ago" when it's only a rough guess, rather than faking precision.
const isBacklog = book.data.status === 'backlog';
const readStamp =
  book.data.readApprox || !book.data.readAt
    ? strings.timeline.longAgo
    : new Intl.DateTimeFormat(bcp47Locale(locale), {
        month: 'short',
        year: 'numeric',
      }).format(book.data.readAt);

// Some entries carry a personal note in the body; others just repeat the
// summary verbatim (or are empty). Only open a notes section when the body
// genuinely adds something beyond the standfirst — no more duplication.
const bodyText = (book.body ?? '').trim();
const hasNotes = bodyText.length > 0 && bodyText !== book.data.summary.trim();
---

<BaseLayout
  locale={locale}
  title={`${book.data.title} — ${book.data.author}`}
  description={book.data.summary}
  alternatePath={`books/${book.slug}`}
  ogImage={`/og/book-${book.slug}.png`}
  fullViewport
  hideFooter
>
  <article class="book" data-pagefind-body>
    <p class="workbench breadcrumb">
      <a href={localePath(locale, 'inspiration')}>{strings.books.backToBooks}</a>
    </p>

    {/* ── Spread: the cover plate beside its catalog card + notes. ───── */}
    <div class="spread">
      <aside class="plate-rail">
        <div class="cover" aria-hidden="true">
          <img src={book.data.cover} alt="" loading="eager" />
        </div>
      </aside>

      <div class="reading">
        <p class="workbench stamps">
          <span class="stamp stamp-read">{isBacklog ? strings.books.backlog : `${strings.books.read} · ${readStamp}`}</span>
          {hasRating && (
            <span class="stamp rating" aria-label={`${rating} / 5`}>
              <span class="stars-filled">{'★'.repeat(rating)}</span><span class="stars-empty">{'★'.repeat(5 - rating)}</span>
            </span>
          )}
          {category && <span class="stamp cat">{category}</span>}
        </p>

        <h1 class="title">{book.data.title}</h1>
        <p class="author"><span class="by">{strings.books.by}</span> <span class="name">{book.data.author}</span></p>

        {/* The summary is the at-a-glance blurb; when full notes exist they
            carry it, so show it only as the standfirst for note-less books. */}
        {hasNotes ? (
          <section class="notes">
            <div class="notes-body">
              <Content />
            </div>
          </section>
        ) : (
          <p class="summary">{book.data.summary}</p>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* ── Mobile / narrow: a stacked flow ─────────────────────────────── */
  .book {
    /* One small, semantic type scale used throughout: a display size for
       the title, a lede size for the standfirst, and one body size shared
       by the author line and the notes. Mono UI labels keep .workbench. */
    --fs-title: clamp(1.85rem, 1.6vw + 1.15rem, 2.4rem);
    --fs-lede: 1.25rem;
    --fs-body: 1.05rem;

    max-width: 60rem;
    margin-inline: auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .breadcrumb {
    margin: 0 0 var(--space-4);
  }
  .breadcrumb a {
    color: var(--ink-muted);
    border-bottom: none;
  }
  .breadcrumb a:hover {
    background: transparent;
    color: var(--orange-accent);
  }

  .spread {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  /* The cover is a tipped-in plate with the site's hard offset shadow. */
  .cover {
    width: min(190px, 52vw);
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--rule);
    border-radius: 2px;
    box-shadow: 7px 9px 0 0 var(--rule);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .cover:hover {
    transform: translate(-2px, -2px);
    box-shadow: 10px 12px 0 0 var(--rule);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Reading column: stamps, title, author, standfirst, notes. ───── */
  .reading {
    min-width: 0;
    max-width: var(--measure);
  }
  .stamps {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 0.6rem;
    margin: 0 0 var(--space-2);
    color: var(--ink-muted);
  }
  .stamp:not(:first-child)::before {
    content: '·';
    color: var(--rule);
    margin-right: 0.55rem;
  }
  .stamp-read {
    color: var(--green-primary);
  }
  .rating {
    letter-spacing: 0.12em;
    font-size: 1.7rem;
    line-height: 1;
  }
  .stars-filled {
    color: var(--orange-accent);
  }
  .stars-empty {
    color: var(--ink-muted);
    opacity: 0.35;
  }
  .cat {
    letter-spacing: 0.08em;
  }

  .title {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }
  .author {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.4;
  }
  .author .by {
    font-size: 0.86em;
    letter-spacing: 0.01em;
  }
  .author .name {
    font-style: italic;
    color: var(--ink);
  }

  /* Summary as the standfirst — the book's essence, stated once. */
  .summary {
    font-family: var(--font-display);
    font-size: var(--fs-lede);
    font-weight: 450;
    line-height: 1.5;
    color: var(--ink);
    margin: var(--space-3) 0 0;
    text-wrap: pretty;
  }

  /* ── Notes: only present when there's a real annotation. ─────────── */
  .notes {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--rule);
  }
  .notes-body {
    font-size: var(--fs-body);
    line-height: var(--leading-body);
  }
  .notes-body :global(p) {
    margin: 0 0 var(--space-3);
  }
  .notes-body :global(p:last-child) {
    margin-bottom: 0;
  }
  /* Embedded cards (e.g. a tweet) need the same rhythm as paragraphs. */
  .notes-body :global(.tweet) {
    margin: 0 0 var(--space-3);
  }
  .notes-body :global(blockquote) {
    border-left: 3px solid var(--green-primary);
    padding: 0 0 0 var(--space-3);
    margin: 0 0 var(--space-3);
    color: var(--ink-muted);
    font-style: italic;
  }
  .notes-body :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: var(--space-4) 0 var(--space-3);
  }
  .notes-body :global(em) {
    color: var(--ink-muted);
  }
  /* Retracted notes — struck through and faded. */
  .notes-body :global(del) {
    color: var(--ink-muted);
    opacity: 0.7;
    text-decoration-thickness: 1px;
  }
  .notes-body :global(a) {
    color: var(--green-primary);
  }
  .notes-body :global(img),
  .notes-body :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }
  .notes-body :global(ul) {
    list-style: disc outside;
    padding-inline-start: 1.4rem;
  }
  .notes-body :global(ol) {
    list-style: decimal outside;
    padding-inline-start: 1.6rem;
  }
  .notes-body :global(li) {
    margin-bottom: 0.4rem;
  }

  /* ════════════════════════════════════════════════════════════════
     Desktop: a two-column spread that fills the screen. Soft fill (no
     overflow lock) — short entries fill the viewport, long notes simply
     grow the page and scroll.
     ════════════════════════════════════════════════════════════════ */
  @media (min-width: 960px) {
    :global(body.full-viewport main) {
      display: flex;
    }
    .book {
      flex: 1;
      max-width: none;
      margin: 0;
      padding: var(--space-4) clamp(var(--space-4), 5vw, var(--space-6)) var(--space-5);
    }
    .spread {
      flex: 1 1 auto;
      grid-template-columns: clamp(200px, 26vw, 300px) minmax(0, 1fr);
      gap: clamp(var(--space-4), 5vw, var(--space-6));
      align-items: start;
    }
    .cover {
      width: 100%;
    }
    .reading {
      /* The notes want a comfortable measure; the title can run wider. */
      max-width: 60ch;
    }
    /* Nudge only the display size up on the wider canvas; lede/body hold. */
    .book {
      --fs-title: clamp(2.1rem, 1.8vw + 1.2rem, 2.8rem);
    }
  }
</style>
