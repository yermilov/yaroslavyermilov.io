---
import { LOCALES, t, localePath, bcp47Locale, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getBooks } from '@lib/content';

export async function getStaticPaths() {
  const books = await getBooks();
  return LOCALES.flatMap((locale) =>
    books.map((book) => ({
      params: { locale, slug: book.slug },
      props: { book },
    })),
  );
}

const { book } = Astro.props;
const locale = Astro.params.locale as Locale;
const strings = t(locale);
const { Content } = await book.render();

const rating = book.data.rating ?? 0;
const category = book.data.series || book.data.genre || null;

// The read date is real data the old page never surfaced — stamp it.
const readStamp = new Intl.DateTimeFormat(bcp47Locale(locale), {
  month: 'short',
  year: 'numeric',
}).format(book.data.readAt);

// Some entries carry a personal note in the body; others just repeat the
// summary verbatim (or are empty). Only open a notes section when the body
// genuinely adds something beyond the standfirst — no more duplication.
const bodyText = (book.body ?? '').trim();
const hasNotes = bodyText.length > 0 && bodyText !== book.data.summary.trim();
---

<BaseLayout
  locale={locale}
  title={`${book.data.title} — ${book.data.author}`}
  description={book.data.summary}
  alternatePath={`books/${book.slug}`}
  ogImage={`/og/book-${book.slug}.png`}
>
  <article class="page-frame book" data-pagefind-body>
    <p class="workbench breadcrumb">
      <a href={localePath(locale, 'inspiration')}>{strings.books.backToBooks}</a>
    </p>

    {/* ── Catalog plate: the cover tipped in beside its catalog card. ── */}
    <div class="plate">
      <aside class="cover" aria-hidden="true">
        <img src={book.data.cover} alt="" loading="eager" />
      </aside>

      <div class="card">
        <p class="workbench stamps">
          <span class="stamp stamp-read">{strings.books.read} · {readStamp}</span>
          {rating > 0 && (
            <span class="stamp rating" aria-label={`${rating} / 5`}>
              <span class="stars-filled">{'★'.repeat(rating)}</span><span class="stars-empty">{'★'.repeat(5 - rating)}</span>
            </span>
          )}
          {category && <span class="stamp cat">{category}</span>}
        </p>

        <h1 class="title">{book.data.title}</h1>
        <p class="author"><span class="by">{strings.books.by}</span> <span class="name">{book.data.author}</span></p>

        <p class="summary">{book.data.summary}</p>
      </div>
    </div>

    {hasNotes && (
      <section class="notes">
        <p class="workbench notes-label">/ {strings.books.notes}</p>
        <div class="notes-body">
          <Content />
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .book {
    max-width: 60rem;
    margin-inline: auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
  }

  .breadcrumb {
    margin: 0 0 var(--space-5);
  }
  .breadcrumb a {
    color: var(--ink-muted);
    border-bottom: none;
  }
  .breadcrumb a:hover {
    background: transparent;
    color: var(--orange-accent);
  }

  /* ── Plate: cover plate + catalog card, spending width not height. ── */
  .plate {
    display: grid;
    grid-template-columns: clamp(168px, 24vw, 232px) minmax(0, 1fr);
    gap: clamp(var(--space-3), 4vw, var(--space-5));
    align-items: start;
  }

  /* The cover is a tipped-in plate with the site's hard offset shadow. */
  .cover {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--rule);
    border-radius: 2px;
    box-shadow: 7px 9px 0 0 var(--rule);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .cover:hover {
    transform: translate(-2px, -2px);
    box-shadow: 10px 12px 0 0 var(--rule);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Catalog card: stamps, title, author, standfirst, action. ────── */
  .stamps {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.55rem;
    margin: 0 0 var(--space-2);
    color: var(--ink-muted);
  }
  .stamp:not(:first-child)::before {
    content: '·';
    color: var(--rule);
    margin-right: 0.55rem;
  }
  .stamp-read {
    color: var(--green-primary);
  }
  .rating {
    letter-spacing: 0.08em;
    font-size: 0.92rem;
    line-height: 1;
  }
  .stars-filled {
    color: var(--orange-accent);
  }
  .stars-empty {
    color: var(--ink-muted);
    opacity: 0.35;
  }
  .cat {
    letter-spacing: 0.08em;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.4vw + 0.8rem, 2.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }
  .author {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.4;
  }
  .author .by {
    font-size: 0.86em;
    letter-spacing: 0.01em;
  }
  .author .name {
    font-style: italic;
    color: var(--ink);
  }

  /* Summary as the standfirst — the book's essence, stated once. */
  .summary {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 0.7vw + 1rem, 1.4rem);
    font-weight: 450;
    line-height: 1.5;
    color: var(--ink);
    margin: var(--space-3) 0 0;
    max-width: 42ch;
    text-wrap: pretty;
  }

  /* ── Notes: only present when there's a real annotation. ─────────── */
  .notes {
    max-width: var(--measure);
    margin-top: clamp(var(--space-5), 7vw, var(--space-6));
    padding-top: var(--space-4);
    border-top: 1px solid var(--rule);
  }
  .notes-label {
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
  }
  .notes-body {
    line-height: var(--leading-body);
  }
  .notes-body :global(p) {
    margin: 0 0 var(--space-3);
  }
  .notes-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .notes-body :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: var(--space-4) 0 var(--space-3);
  }
  .notes-body :global(em) {
    color: var(--ink-muted);
  }
  .notes-body :global(a) {
    color: var(--green-primary);
  }
  .notes-body :global(img),
  .notes-body :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }
  .notes-body :global(ul) {
    list-style: disc outside;
    padding-inline-start: 1.4rem;
  }
  .notes-body :global(ol) {
    list-style: decimal outside;
    padding-inline-start: 1.6rem;
  }
  .notes-body :global(li) {
    margin-bottom: 0.4rem;
  }

  /* ── Narrow: the plate stacks, cover left at a calmer size. ──────── */
  @media (max-width: 600px) {
    .plate {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .cover {
      width: min(180px, 52vw);
    }
    .summary {
      font-size: 1.2rem;
    }
  }
</style>
