---
import { LOCALES, t, bcp47Locale, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import TalkCard from '@components/TalkCard.astro';
import { getTalks } from '@lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const talks = await getTalks();

const today = new Date();
today.setHours(0, 0, 0, 0);

function atMidnight(d: Date): Date {
  const x = new Date(d);
  x.setHours(0, 0, 0, 0);
  return x;
}

const upcoming = talks.filter((talk) => atMidnight(talk.data.date) >= today);
const past = talks.filter((talk) => atMidnight(talk.data.date) < today);
upcoming.reverse(); // soonest first

const rtf = new Intl.RelativeTimeFormat(bcp47Locale(locale), {
  numeric: 'auto',
});
const daysFromToday = (date: Date): number =>
  Math.round((atMidnight(date).getTime() - today.getTime()) / 86_400_000);

function bucketOf(days: number): 'today' | 'tomorrow' | 'yesterday' | 'other' {
  if (days === 0) return 'today';
  if (days === 1) return 'tomorrow';
  if (days === -1) return 'yesterday';
  return 'other';
}

const head = upcoming[0];
const headDays = head ? daysFromToday(head.data.date) : 0;
const headIso = head?.data.date.toISOString() ?? '';
const headFallback = head ? rtf.format(headDays, 'day') : '';
const headBucket = head ? bucketOf(headDays) : 'other';
---

<BaseLayout locale={locale} title={strings.nav.talks} alternatePath="talks">
  <section class="page-frame index">
    {talks.length === 0 ? (
      <div class="prose-column">
        <p class="empty">{strings.empty.talks}</p>
      </div>
    ) : (
      <>
        <div
          class="prose-column upcoming"
          data-programme="upcoming"
          data-bcp47={bcp47Locale(locale)}
          hidden={upcoming.length === 0}
        >
          <p class="workbench upcoming-tag">
            ▸ {strings.talks.nextUp} · <span
              class={`rel-days rel-days--${headBucket}`}
              data-rel-days-target
              data-iso={headIso}
            >{headFallback}</span>
          </p>
          <ul class="talk-list" role="list">
            {upcoming.map((talk) => (
              <li data-iso={talk.data.date.toISOString()}><TalkCard talk={talk} locale={locale} /></li>
            ))}
          </ul>
        </div>

        <div
          class="prose-column past"
          data-programme="past"
          hidden={past.length === 0}
        >
          <p
            class="workbench past-tag"
            data-past-tag
            hidden={upcoming.length === 0}
          >/ {strings.talks.past}</p>
          <ul class="talk-list" role="list">
            {past.map((talk) => (
              <li data-iso={talk.data.date.toISOString()}><TalkCard talk={talk} locale={locale} /></li>
            ))}
          </ul>
        </div>
      </>
    )}
  </section>
</BaseLayout>

<script>
  import { reconcileProgramme, updateRelDaysSpan } from '@lib/programme-reconcile';

  const upcomingSection = document.querySelector<HTMLElement>('[data-programme="upcoming"]');
  const pastSection = document.querySelector<HTMLElement>('[data-programme="past"]');
  const upcomingList = upcomingSection?.querySelector<HTMLElement>('.talk-list');
  const pastList = pastSection?.querySelector<HTMLElement>('.talk-list');

  if (upcomingSection && pastSection && upcomingList && pastList) {
    const bcp47 = upcomingSection.dataset.bcp47 || 'en-US';
    const pastTag = pastSection.querySelector<HTMLElement>('[data-past-tag]');
    const headSpan = upcomingSection.querySelector<HTMLElement>('[data-rel-days-target]');

    reconcileProgramme({
      upcomingSection,
      recentSection: pastSection,
      upcomingList,
      recentList: pastList,
      onUpcomingHeadChange: (newHead) => {
        if (pastTag) pastTag.hidden = !newHead;
        if (!newHead || !headSpan) return;
        const iso = newHead.getAttribute('data-iso');
        if (iso) {
          headSpan.setAttribute('data-iso', iso);
          updateRelDaysSpan(headSpan, iso, bcp47);
        }
      },
    });
  }
</script>

<style>
  .index {
    padding: var(--space-5) var(--space-3) var(--space-6);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
  }
  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .upcoming {
    border-left: 3px solid var(--green-primary);
    padding-left: var(--space-3);
    margin-bottom: var(--space-5);
  }
  .upcoming-tag {
    color: var(--green-primary);
    margin: 0 0 0.4rem;
  }
  /* The single upcoming talk has no peers below it; drop its bottom rule
     so the green-bordered block ends cleanly. */
  .upcoming :global(.talk:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }
  .past-tag {
    border-top: 1px solid var(--rule);
    padding-top: var(--space-3);
    margin: 0 0 var(--space-2);
  }
</style>
