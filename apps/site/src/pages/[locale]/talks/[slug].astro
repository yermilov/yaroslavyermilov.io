---
import { getCollection, type CollectionEntry } from 'astro:content';
import { LOCALES, t, localePath, languageBadge, bcp47Locale, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import LinkedInCard from '@components/LinkedInCard.astro';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.flatMap((talk) =>
    LOCALES.map((locale) => ({
      params: { locale, slug: talk.slug },
      props: { talk },
    })),
  );
}

const { talk } = Astro.props as { talk: CollectionEntry<'talks'> };
const locale = Astro.params.locale as Locale;
const strings = t(locale);
const bcp47 = bcp47Locale(locale);

const dateFmt = new Intl.DateTimeFormat(bcp47, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

/** YouTube parsing — preserves `?t=` start offset across share-link variants. */
function parseStart(t: string | null): number | undefined {
  if (!t) return undefined;
  const m = t.match(/^(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s?)?$/);
  if (!m) return undefined;
  const [, h, mn, s] = m;
  const total =
    parseInt(h || '0') * 3600 + parseInt(mn || '0') * 60 + parseInt(s || '0');
  return total > 0 ? total : undefined;
}
function parseYouTube(url: string | undefined): { id: string; start?: number } | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    const start = parseStart(u.searchParams.get('t'));
    if (u.hostname === 'youtu.be') {
      return { id: u.pathname.slice(1), start };
    }
    if (u.hostname.endsWith('youtube.com')) {
      const v = u.searchParams.get('v');
      if (v) return { id: v, start };
      const m = u.pathname.match(/\/(?:live|embed|shorts)\/([^/?]+)/);
      if (m && m[1]) return { id: m[1], start };
    }
  } catch {
    /* fall through */
  }
  return null;
}
const yt = parseYouTube(talk.data.videoUrl);
const embedUrl = yt
  ? `https://www.youtube-nocookie.com/embed/${yt.id}${yt.start ? `?start=${yt.start}` : ''}`
  : null;

/**
 * SlideShare → embed URL. Canonical:
 *   https://www.slideshare.net/slideshow/<slug>/<numeric-id>
 * Embed:
 *   https://www.slideshare.net/slideshow/embed_code/<numeric-id>
 */
function parseSlideShare(url: string | undefined): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    if (!u.hostname.endsWith('slideshare.net')) return null;
    const m = u.pathname.match(/\/slideshow\/[^/]+\/(\d+)\/?$/);
    if (m && m[1]) return `https://www.slideshare.net/slideshow/embed_code/${m[1]}`;
    return null;
  } catch {
    return null;
  }
}
const slidesEmbedUrl = parseSlideShare(talk.data.slidesUrl);

const paragraphs = talk.data.abstract.split(/\n\n+/);

/**
 * Server-rendered relative time. Only emitted for talks older than 30 days,
 * so the build-vs-visit clock drift can't bend a day-precision number into
 * something wrong. Unit auto-selects between months and years.
 */
function buildRelative(date: Date): string | null {
  const days = Math.floor((Date.now() - date.getTime()) / 86_400_000);
  if (days < 30) return null;
  const rtf = new Intl.RelativeTimeFormat(bcp47, { numeric: 'auto' });
  const years = Math.floor(days / 365.25);
  if (years >= 1) return rtf.format(-years, 'year');
  const months = Math.floor(days / 30.44);
  return rtf.format(-months, 'month');
}
const relative = buildRelative(talk.data.date);

/**
 * Artifacts present on this talk. The order defines the numbered acts
 * — talks with only slides + photos get them as 01 and 02, not 02 and 03.
 */
type Artifact = 'recording' | 'slides' | 'repo' | 'photos' | 'feedback';
const artifacts: Artifact[] = [];
if (embedUrl || talk.data.videoUrl || talk.data.videoOnRequest) artifacts.push('recording');
if (slidesEmbedUrl || talk.data.slidesUrl) artifacts.push('slides');
if (talk.data.repoUrl) artifacts.push('repo');
if (talk.data.feedback.length > 0) artifacts.push('feedback');
if (talk.data.photos.length > 0) artifacts.push('photos');

const feedbackDateFmt = new Intl.DateTimeFormat(bcp47, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

/** Primary contact channel surfaced for on-request recordings. */
const linkedInUrl = 'https://www.linkedin.com/in/yarik-yermilov/';
const ord = (kind: Artifact): string => String(artifacts.indexOf(kind) + 1).padStart(2, '0');

const artifactLabel: Record<Artifact, string> = {
  recording: strings.talks.recording,
  slides: strings.talks.slides,
  photos: strings.talks.photos,
  repo: strings.talks.repo,
  feedback: strings.talks.feedback,
};
---

<BaseLayout
  locale={locale}
  title={talk.data.title}
  description={paragraphs[0]}
  alternatePath={`talks/${talk.slug}`}
  ogImage={`/og/talk-${talk.slug}.png`}
>
  <article class="page-frame talk-detail">
    <p class="workbench breadcrumb">
      / <a href={localePath(locale, 'writing-talking/talking')}>{strings.subnav.talking.toUpperCase()}</a> /
    </p>

    <header class="hero">
      <p class="kicker">
        <span aria-hidden="true">▸ </span>
        {talk.data.eventUrl ? (
          <a class="event-link" href={talk.data.eventUrl} rel="noopener">{talk.data.event}</a>
        ) : (
          <span>{talk.data.event}</span>
        )}
      </p>

      <h1 class="title">{talk.data.title}</h1>

      <p class="credit">
        <time datetime={talk.data.date.toISOString()}>{dateFmt.format(talk.data.date)}</time>
        {talk.data.language && <span>{languageBadge(talk.data.language)}</span>}
        {relative && <span>{relative}</span>}
      </p>

      {artifacts.length >= 2 && (
        <nav class="jump" aria-label="jump-nav">
          {artifacts.map((a) => (
            <a href={`#${a}`}>{artifactLabel[a].toLowerCase()}</a>
          ))}
        </nav>
      )}
    </header>

    <hr class="hero-rule" />

    <section class="lede prose-narrow">
      {paragraphs.map((p, i) => (
        <p class={i === 0 ? 'lead' : 'body'}>{p}</p>
      ))}
    </section>

    {(embedUrl || talk.data.videoUrl || talk.data.videoOnRequest) && (
      <section class="act" id="recording">
        <p class="act-label workbench"><span class="ord">▸ {ord('recording')}</span> · {strings.talks.recording}</p>
        {embedUrl ? (
          <div class="media-frame video-frame">
            <iframe
              src={embedUrl}
              title={talk.data.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        ) : talk.data.videoUrl ? (
          <a class="external-card" href={talk.data.videoUrl} rel="noopener" target="_blank">
            <span class="external-label">{strings.talks.recording}</span>
            <span class="external-host">{new URL(talk.data.videoUrl).hostname.replace(/^www\./, '')}{new URL(talk.data.videoUrl).pathname}</span>
            <span class="external-arrow" aria-hidden="true">↗</span>
          </a>
        ) : (
          <a class="external-card" href={linkedInUrl} rel="noopener" target="_blank">
            <span class="external-label">{strings.talks.recording}</span>
            <span class="external-host">{strings.talks.recordingOnRequest}</span>
            <span class="external-arrow" aria-hidden="true">↗</span>
          </a>
        )}
      </section>
    )}

    {slidesEmbedUrl && (
      <section class="act" id="slides">
        <p class="act-label workbench"><span class="ord">▸ {ord('slides')}</span> · {strings.talks.slides}</p>
        <div class="media-frame slides-frame">
          <iframe
            src={slidesEmbedUrl}
            title={`${talk.data.title} — slides`}
            loading="lazy"
            allowfullscreen
          ></iframe>
        </div>
      </section>
    )}

    {!slidesEmbedUrl && talk.data.slidesUrl && (
      <section class="act" id="slides">
        <p class="act-label workbench"><span class="ord">▸ {ord('slides')}</span> · {strings.talks.slides}</p>
        <a class="external-card" href={talk.data.slidesUrl} rel="noopener" target="_blank">
          <span class="external-label">{strings.talks.slides}</span>
          <span class="external-host">{new URL(talk.data.slidesUrl).hostname.replace(/^www\./, '')}</span>
          <span class="external-arrow" aria-hidden="true">↗</span>
        </a>
      </section>
    )}

    {talk.data.repoUrl && (
      <section class="act" id="repo">
        <p class="act-label workbench"><span class="ord">▸ {ord('repo')}</span> · {strings.talks.repo}</p>
        <a class="external-card" href={talk.data.repoUrl} rel="noopener" target="_blank">
          <span class="external-label">{strings.talks.repo}</span>
          <span class="external-host">{new URL(talk.data.repoUrl).hostname.replace(/^www\./, '')}{new URL(talk.data.repoUrl).pathname}</span>
          <span class="external-arrow" aria-hidden="true">↗</span>
        </a>
      </section>
    )}

    {talk.data.feedback.length > 0 && (
      <section class="act" id="feedback">
        <p class="act-label workbench"><span class="ord">▸ {ord('feedback')}</span> · {strings.talks.feedback} <span class="count">— {talk.data.feedback.length}</span></p>
        <ul class="feedback-wall" role="list">
          {talk.data.feedback.map((f) => (
            <li>
              <LinkedInCard
                url={f.url}
                author={f.author}
                headline={f.headline}
                avatar={f.avatar}
                date={f.date ? feedbackDateFmt.format(f.date) : undefined}
              >
                {f.excerpt}
              </LinkedInCard>
            </li>
          ))}
        </ul>
      </section>
    )}

    {talk.data.photos.length > 0 && (
      <section class="act" id="photos">
        <p class="act-label workbench"><span class="ord">▸ {ord('photos')}</span> · {strings.talks.photos} <span class="count">— {talk.data.photos.length}</span></p>
        <ul class="contact-sheet" role="list">
          {talk.data.photos.map((src, i) => (
            <li>
              <a href={src} target="_blank" rel="noopener" aria-label={`Photo ${i + 1}`}>
                <span class="frame">
                  <img src={src} alt="" loading="lazy" />
                </span>
                <span class="caption">№{String(i + 1).padStart(2, '0')}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="closing">
      <hr class="closing-rule" />
      <p class="back-link workbench">
        <a href={localePath(locale, 'writing-talking/talking')}>{strings.talks.backToTalks}</a>
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  /* ── Page chrome ───────────────────────────────────────────────── */
  .talk-detail {
    padding: var(--space-3) var(--space-3) var(--space-6);
  }
  .breadcrumb {
    margin: 0 0 var(--space-3);
    color: var(--ink-muted);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }
  .breadcrumb a {
    border-bottom: none;
    color: var(--ink-muted);
  }
  .breadcrumb a:hover {
    background: transparent;
    color: var(--orange-accent);
  }

  /* ── Hero — playbill treatment ─────────────────────────────────── */
  .hero {
    /* Page-load reveal: kicker → title → credit → jump, each delayed. */
    --reveal-distance: 8px;
  }
  .hero > * {
    opacity: 0;
    transform: translateY(var(--reveal-distance));
    animation: rise 480ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .kicker          { animation-delay:  60ms; }
  .title           { animation-delay: 140ms; }
  .credit          { animation-delay: 260ms; }
  .jump            { animation-delay: 360ms; }
  @keyframes rise {
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero > * {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green-primary);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }
  .kicker .event-link {
    border-bottom: none;
    color: var(--green-primary);
  }
  .kicker .event-link:hover {
    background: transparent;
    color: var(--orange-accent);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    /* Poster-sized but with a hard ceiling so very long titles don't
       crash through layout on 4K screens. */
    font-size: clamp(2.1rem, 5.4vw + 0.4rem, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.022em;
    margin: 0 0 var(--space-3);
    text-wrap: balance;
    color: var(--ink);
    max-width: 22ch;
  }

  /* Credit: date · language · "9 years ago" with `·` rendered between
     items via ::before so missing language or recent-talk-no-relative
     can't leave a dangling separator. */
  .credit {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.6rem;
    line-height: 1.6;
  }
  .credit > *:not(:first-child)::before {
    content: '·';
    color: var(--rule);
    margin-right: 0.6rem;
  }
  .credit time {
    color: var(--ink);
  }

  .jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin: 0;
    color: var(--ink-muted);
  }
  .jump > a {
    border-bottom: none;
    color: var(--ink-muted);
    padding: 0.1rem 0;
    transition: color 120ms ease, transform 120ms ease;
  }
  .jump > a:hover {
    background: transparent;
    color: var(--orange-accent);
    transform: translateX(2px);
  }
  .jump > a + a::before {
    content: '·';
    color: var(--rule);
    margin-right: 0.6rem;
  }

  .hero-rule {
    border: none;
    border-top: 3px solid var(--green-deep);
    margin: var(--space-3) 0 var(--space-4);
  }

  /* ── Lede / abstract ───────────────────────────────────────────── */
  .prose-narrow {
    max-width: 68ch;
  }
  .lede {
    margin: 0 0 var(--space-5);
  }
  .lede .lead {
    font-size: 1.18rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 var(--space-3);
    text-wrap: pretty;
  }
  .lede .body {
    font-size: 1.075rem;
    line-height: var(--leading-body);
    color: var(--ink);
    margin: 0 0 var(--space-3);
  }
  .lede p:last-child {
    margin-bottom: 0;
  }

  /* ── Acts (recording / slides / photos / repo) ─────────────────── */
  .act {
    margin: 0 0 var(--space-5);
    scroll-margin-top: var(--space-4);
  }
  .act-label {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--green-primary);
    margin: 0 0 var(--space-2);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.5em;
  }
  .act-label .ord {
    color: var(--ink-muted);
    font-weight: 500;
  }
  .act-label .count {
    color: var(--ink-muted);
    text-transform: lowercase;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }

  /* ── Media frame: shared envelope for video + slides iframes ──── */
  .media-frame {
    width: 100%;
    border: 1px solid var(--rule);
    border-top: 3px solid var(--green-deep);
    background: var(--bg-elevated);
    /* Letterpress shadow vocabulary borrowed from book covers & index cards. */
    box-shadow: 5px 6px 0 0 var(--rule);
  }
  .media-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .video-frame {
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .slides-frame {
    aspect-ratio: 4 / 3;
  }

  /* ── External card: when slides/repo aren't embeddable ─────────── */
  .external-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.6rem 1rem;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--green-deep);
    background: var(--bg-elevated);
    box-shadow: 5px 6px 0 0 var(--rule);
    font-family: var(--font-mono);
    color: var(--ink);
    transition: transform 160ms ease, box-shadow 160ms ease, color 160ms ease;
  }
  .external-card:hover {
    background: var(--bg-elevated);
    transform: translate(-1px, -1px);
    box-shadow: 7px 8px 0 0 var(--rule);
    color: var(--ink);
  }
  .external-label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--green-primary);
  }
  .external-host {
    font-size: 0.92rem;
    color: var(--ink-muted);
    word-break: break-all;
  }
  .external-arrow {
    font-size: 1.2rem;
    color: var(--orange-accent);
    transition: transform 160ms ease;
  }
  .external-card:hover .external-arrow {
    transform: translate(3px, -3px);
  }

  /* ── Contact sheet — photos as numbered frames ─────────────────── */
  .contact-sheet {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3) var(--space-2);
  }
  .contact-sheet a {
    display: block;
    border: none;
    color: var(--ink-muted);
    text-decoration: none;
  }
  .contact-sheet a:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .contact-sheet .frame {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    box-shadow: 3px 4px 0 0 var(--rule);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .contact-sheet a:hover .frame {
    transform: translate(-1px, -1px);
    box-shadow: 5px 6px 0 0 var(--rule);
  }
  .contact-sheet img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .contact-sheet .caption {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }
  @media (max-width: 540px) {
    .contact-sheet {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
  }

  /* ── Feedback wall — quoted LinkedIn posts ─────────────────────── */
  .feedback-wall {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-3);
    align-items: start;
  }
  .feedback-wall > li {
    min-width: 0;
  }

  /* ── Closing tombstone ─────────────────────────────────────────── */
  .closing {
    margin-top: var(--space-5);
  }
  .closing-rule {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 0 0 var(--space-3);
  }
  .back-link {
    margin: 0;
    font-size: 0.85rem;
  }
  .back-link a {
    border-bottom: none;
    color: var(--ink-muted);
    transition: color 120ms ease, transform 120ms ease;
    display: inline-block;
  }
  .back-link a:hover {
    background: transparent;
    color: var(--orange-accent);
    transform: translateX(-3px);
  }

  /* ── Narrow viewports ──────────────────────────────────────────── */
  @media (max-width: 540px) {
    .title {
      max-width: none;
    }
    .media-frame,
    .external-card {
      box-shadow: 3px 4px 0 0 var(--rule);
    }
  }
</style>
