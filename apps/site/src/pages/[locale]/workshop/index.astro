---
import { LOCALES, t, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionMasthead from '@components/SectionMasthead.astro';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const ws = strings.workshop;

const offers = [
  { index: '01', title: ws.offerOneTitle, desc: ws.offerOneDesc },
  { index: '02', title: ws.offerTwoTitle, desc: ws.offerTwoDesc },
];
---

<BaseLayout locale={locale} title={strings.nav.workshop} alternatePath="workshop">
  <section class="page-frame workshop">
    <SectionMasthead eyebrow="vol. 04" title={ws.headline} lede={ws.lede} />

    <ul class="offers" role="list">
      {offers.map((offer) => (
        <li class="offer">
          <p class="workbench offer-index">{offer.index}</p>
          <h2 class="offer-title">{offer.title}</h2>
          <p class="offer-desc">{offer.desc}</p>
        </li>
      ))}
    </ul>

    <p class="workbench note">▸ {ws.note}</p>

    <a
      class="cta"
      href="https://www.linkedin.com/in/yarik-yermilov/"
      rel="me noopener"
      target="_blank"
    >
      <span class="workbench cta-eyebrow">→ {ws.ctaEyebrow}</span>
      <span class="cta-headline">
        {ws.ctaHeadline}<span class="cta-arrow" aria-hidden="true">↗</span>
      </span>
      <span class="workbench cta-handle">{ws.ctaHandle}</span>
    </a>
  </section>
</BaseLayout>

<style>
  .workshop {
    padding: 0 var(--space-3) var(--space-6);
  }

  /* Two offer cards with the site's hard offset shadow — printed flyers
     pinned to the workbench. */
  .offers {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .offer {
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    box-shadow: 4px 5px 0 0 var(--rule);
    padding: var(--space-3) var(--space-3) var(--space-4);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .offer:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 8px 0 0 var(--rule);
  }
  .offer-index {
    color: var(--orange-accent);
    font-weight: 700;
    margin: 0 0 var(--space-2);
  }
  .offer-title {
    font-size: 1.5rem;
    margin: 0 0 var(--space-2);
  }
  .offer-desc {
    color: var(--ink-muted);
    margin: 0;
  }

  .note {
    color: var(--green-primary);
    margin: 0 0 var(--space-5);
    max-width: var(--measure);
  }

  /* CTA — the "elsewhere" typographic vocabulary from the homepage hero,
     scaled up into the page's closing statement. */
  .cta {
    display: inline-flex;
    flex-direction: column;
    gap: 0.4rem;
    border: none;
    line-height: 1.1;
    color: var(--ink);
  }
  .cta:hover {
    background: transparent;
    color: var(--ink);
  }
  .cta-eyebrow {
    color: var(--green-primary);
  }
  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    transition: color 140ms ease;
  }
  .cta-arrow {
    display: inline-block;
    margin-left: 0.18em;
    font-size: 0.65em;
    color: var(--orange-accent);
    transition: transform 160ms ease, color 160ms ease;
    vertical-align: 0.4em;
  }
  .cta-handle {
    color: var(--ink-muted);
    text-transform: none;
    letter-spacing: 0.01em;
  }
  .cta:hover .cta-headline {
    color: var(--orange-accent);
  }
  .cta:hover .cta-arrow {
    transform: translate(3px, -3px);
    color: var(--orange-bright);
  }
  .cta:hover .cta-handle {
    color: var(--ink);
  }
</style>
