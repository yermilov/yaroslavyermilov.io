---
import { LOCALES, t, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const ws = strings.workshop;

const steps = [
  { index: '01', title: ws.formatOneTitle, desc: ws.formatOneDesc },
  { index: '02', title: ws.formatTwoTitle, desc: ws.formatTwoDesc },
  { index: '03', title: ws.formatThreeTitle, desc: ws.formatThreeDesc },
];

// Both decks are live regardless of reading locale; link straight to them.
const offers = [
  {
    index: '01',
    kicker: ws.offerOneKicker,
    title: ws.offerOneTitle,
    desc: ws.offerOneDesc,
    href: 'https://yaroslavyermilov.io/pragmatic-vibe-clauding-en',
  },
  {
    index: '02',
    kicker: ws.offerTwoKicker,
    title: ws.offerTwoTitle,
    desc: ws.offerTwoDesc,
    href: 'https://yaroslavyermilov.io/revenge-of-the-skill-en',
  },
];
---

<BaseLayout
  locale={locale}
  title={strings.nav.workshop}
  alternatePath="workshop"
  ogImage={`/og/workshop-${locale}.png`}
  fullViewport
  hideFooter
>
  <div class="workshop">
    {/* ── Pitch rail: pitch, how it runs, framing note — all prose ─── */}
    <div class="rail">
      <header class="lead">
        <p class="workbench lead-eyebrow">{ws.eyebrow}</p>
        <h1 class="lead-headline">{ws.headline}</h1>
        <p class="lead-lede">{ws.lede}</p>
      </header>

      <section class="runs" aria-label={ws.formatLabel}>
        <p class="workbench block-label">/ {ws.formatLabel}</p>
        <ul class="runs-list" role="list">
          {steps.map((step) => (
            <li class="run">
              <span class="run-title">{step.title}</span>
              <span class="run-desc"> — {step.desc}</span>
            </li>
          ))}
        </ul>
      </section>

      <p class="workbench note">▸ {ws.note}</p>
    </div>

    {/* ── Body: the two proven formats; testimonials to follow ─────── */}
    <div class="ws-body">
      <section class="formats" aria-label={ws.formatsLabel}>
        <p class="workbench block-label">/ {ws.formatsLabel}</p>
        <ul class="offers" role="list">
          {offers.map((offer) => (
            <li class="offer">
              <p class="workbench offer-kicker">{offer.kicker}</p>
              <h2 class="offer-title">{offer.title}</h2>
              <p class="offer-desc">{offer.desc}</p>
              <a class="workbench offer-deck" href={offer.href} rel="noopener" target="_blank">
                {ws.viewDeck}<span class="offer-deck-arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <a
      class="cta"
      href="https://www.linkedin.com/in/yarik-yermilov/"
      rel="me noopener"
      target="_blank"
    >
      <span class="workbench cta-eyebrow">→ {ws.ctaEyebrow}</span>
      <span class="cta-headline">
        {ws.ctaHeadline}<span class="cta-arrow" aria-hidden="true">↗</span>
      </span>
      <span class="workbench cta-handle">{ws.ctaHandle}</span>
    </a>
  </div>
</BaseLayout>

<style>
  /* ── Mobile / narrow: a simple stacked flow ──────────────────────── */
  .workshop {
    max-width: 64rem;
    margin-inline: auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
  }

  .lead {
    max-width: var(--measure);
    margin-bottom: var(--space-4);
  }
  .lead-eyebrow {
    color: var(--green-primary);
    margin: 0 0 var(--space-2);
  }
  .lead-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.08;
    margin: 0 0 var(--space-3);
  }
  .lead-lede {
    font-size: 1.15rem;
    color: var(--ink-muted);
    margin: 0;
  }

  .rail {
    margin-bottom: var(--space-4);
  }
  .runs {
    margin-bottom: var(--space-4);
  }
  .block-label {
    color: var(--ink-muted);
    margin: 0 0 var(--space-2);
  }

  /* How an engagement runs — plain prose, no ledger chrome. */
  .runs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
    max-width: var(--measure);
  }
  .run {
    line-height: 1.45;
  }
  .run-title {
    font-family: var(--font-display);
    font-weight: 700;
  }
  .run-desc {
    color: var(--ink-muted);
  }

  /* Two offer cards — printed flyers pinned to the workbench. */
  .offers {
    list-style: none;
    margin: 0 0 var(--space-3);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-3);
  }
  .offer {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    box-shadow: 4px 5px 0 0 var(--rule);
    padding: var(--space-3) var(--space-3) var(--space-3);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .offer:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 8px 0 0 var(--rule);
  }
  .offer-kicker {
    color: var(--green-primary);
    text-transform: none;
    letter-spacing: 0.01em;
    margin: 0 0 0.3rem;
  }
  .offer-title {
    font-size: 1.4rem;
    margin: 0 0 var(--space-2);
  }
  .offer-desc {
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
  }
  .offer-deck {
    color: var(--green-primary);
    border-bottom: 1.5px solid transparent;
    align-self: flex-start;
    margin-top: auto;
  }
  .offer-deck:hover {
    background: transparent;
    color: var(--orange-accent);
    border-bottom-color: var(--orange-accent);
  }
  .offer-deck-arrow {
    display: inline-block;
    margin-left: 0.3em;
    color: var(--orange-accent);
    transition: transform 160ms ease;
  }
  .offer-deck:hover .offer-deck-arrow {
    transform: translate(2px, -2px);
  }

  .note {
    color: var(--green-primary);
    margin: 0;
    max-width: var(--measure);
  }

  /* ── CTA — the "elsewhere" typographic vocabulary, scaled up ─────── */
  .cta {
    display: inline-flex;
    flex-direction: column;
    gap: 0.4rem;
    border: none;
    line-height: 1.1;
    color: var(--ink);
    margin-top: var(--space-5);
  }
  .cta:hover {
    background: transparent;
    color: var(--ink);
  }
  .cta-eyebrow {
    color: var(--green-primary);
  }
  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    transition: color 140ms ease;
  }
  .cta-arrow {
    display: inline-block;
    margin-left: 0.18em;
    font-size: 0.65em;
    color: var(--orange-accent);
    transition: transform 160ms ease, color 160ms ease;
    vertical-align: 0.4em;
  }
  .cta-handle {
    color: var(--ink-muted);
    text-transform: none;
    letter-spacing: 0.01em;
  }
  .cta:hover .cta-headline {
    color: var(--orange-accent);
  }
  .cta:hover .cta-arrow {
    transform: translate(3px, -3px);
    color: var(--orange-bright);
  }
  .cta:hover .cta-handle {
    color: var(--ink);
  }

  /* ════════════════════════════════════════════════════════════════
     Split screen (desktop). Left rail = pitch + CTA; right column =
     the substance. Spends width, not height — same ledger grammar as
     the homepage spread.
     ════════════════════════════════════════════════════════════════ */
  @media (min-width: 960px) {
    .workshop {
      max-width: none;
      margin: 0;
      padding: var(--space-4);
      display: grid;
      grid-template-columns: clamp(400px, 42vw, 560px) minmax(0, 1fr);
      grid-template-rows: 1fr auto;
      grid-template-areas:
        'rail body'
        'cta  body';
      column-gap: var(--space-4);
      row-gap: var(--space-3);
    }

    .rail {
      grid-area: rail;
      margin-bottom: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .lead {
      margin-bottom: 0;
      max-width: none;
    }
    .lead-headline {
      font-size: clamp(1.5rem, 2.1vw, 2rem);
      line-height: 1.1;
    }
    .lead-lede {
      font-size: clamp(0.95rem, 1vw, 1.05rem);
      line-height: 1.5;
    }
    .runs {
      margin-bottom: 0;
    }
    .runs-list {
      gap: var(--space-1);
    }
    .run {
      line-height: 1.4;
    }
    .cta-headline {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
    }

    .ws-body {
      grid-area: body;
      min-height: 0;
      display: flex;
      flex-direction: column;
      border-left: 1px solid var(--rule);
      padding-left: var(--space-4);
    }
    /* The cards fill the remaining height so the column reads as one block. */
    .formats {
      display: flex;
      flex-direction: column;
      min-height: 0;
      flex: 1 1 auto;
    }
    .offers {
      margin-bottom: 0;
    }
    .offer-kicker {
      margin-bottom: 0.2rem;
    }
    .offer-title {
      font-size: 1.4rem;
      margin-bottom: var(--space-1);
    }
    /* Cap descriptions so a longer translation can't push the card taller. */
    .offer-desc {
      line-height: 1.55;
      margin-bottom: var(--space-2);
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .cta {
      grid-area: cta;
      align-self: end;
      margin-top: 0;
    }
  }

  /* ── Viewport lock: chrome + spread = exactly one screen. Threshold
     sits just above the content's natural height (longest locale ≈ 724px)
     so shorter windows scroll gracefully instead of clipping. ───────── */
  @media (min-width: 960px) and (min-height: 740px) {
    :global(body.full-viewport) {
      height: 100dvh;
      overflow: hidden;
    }
    :global(body.full-viewport main) {
      display: flex;
      flex: 1 1 auto;
      min-height: 0;
    }
    .workshop {
      height: 100%;
    }
  }

  /* ── Page-load reveal: one staggered rise, then stillness ────────── */
  @media (prefers-reduced-motion: no-preference) and (min-width: 960px) {
    .rail,
    .ws-body,
    .cta {
      animation: ws-rise 480ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
    }
    .rail { animation-delay: 40ms; }
    .ws-body { animation-delay: 160ms; }
    .cta { animation-delay: 280ms; }
  }
  @keyframes ws-rise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
