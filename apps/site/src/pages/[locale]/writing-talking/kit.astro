---
import { LOCALES, t, localePath, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionMasthead from '@components/SectionMasthead.astro';
import SectionTabs from '@components/SectionTabs.astro';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);

const tabs = [
  { href: localePath(locale, 'writing-talking'), label: strings.subnav.all },
  { href: localePath(locale, 'writing-talking/writing'), label: strings.subnav.writing },
  { href: localePath(locale, 'writing-talking/talking'), label: strings.subnav.talking },
  { href: localePath(locale, 'writing-talking/kit'), label: strings.subnav.kit, active: true },
];
---

<BaseLayout locale={locale} title={`${strings.sections.writingTalking.title} — ${strings.subnav.kit}`} alternatePath="writing-talking/kit" ogImage={`/og/writing-talking-${locale}.png`}>
  <section class="page-frame index">
    <SectionMasthead
      eyebrow={`vol. 01 / ${strings.subnav.kit}`}
      title={strings.sections.writingTalking.title}
    />
    <SectionTabs tabs={tabs} label={strings.sections.writingTalking.title} />
    <article class="prose-column kit">
      <h2 class="kit-name">{strings.kit.title}</h2>

      {locale === 'ua' ? (
        <>
          <p>
            Ярослав Єрмілов — Principal Software Engineer у Superhuman
            (раніше Grammarly). Упродовж майже дев’яти років у компанії
            він зосереджувався на 0-to-1 проєктах — від ідеї до запуску.
          </p>
          <p>
            У 2025 році Ярослав був серед перших, хто впроваджував
            AI-розробку в Superhuman: очолив розгортання AI-агентів для
            програмування в масштабі всієї компанії та працював над
            внутрішньою платформою (AI coding harness).
          </p>
          <p>
            Із травня 2025 року він не написав жодного рядка коду
            вручну.
          </p>
        </>
      ) : (
        <>
          <p>
            Yaroslav Yermilov is a Principal Software Engineer at
            Superhuman (formerly Grammarly). Over nearly nine years at
            the company, he has focused on 0-to-1 projects, taking
            ideas from concept to production.
          </p>
          <p>
            In 2025, Yaroslav became one of the early drivers of AI
            coding adoption at Superhuman, leading the rollout of AI
            coding agents across the company and building the internal
            AI coding harness.
          </p>
          <p>
            He hasn’t written a single line of code manually since
            May 2025.
          </p>
        </>
      )}

      <p>
        <a
          href="https://drive.google.com/file/d/1YcuyZfCYJPXIoDvM8e4esTgiyENq16a6/view?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
        >
          {strings.kit.downloadPhoto}
        </a>
      </p>
    </article>
  </section>
</BaseLayout>

<style>
  .index {
    padding: 0 var(--space-3) var(--space-6);
  }
  .kit {
    margin-inline: 0;
  }
  .kit-name {
    margin-top: 0;
    font-size: 1.9rem;
  }
</style>
