---
import { LOCALES, t, pluralize, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionMasthead from '@components/SectionMasthead.astro';
import Timeline from '@components/Timeline.astro';
import { getInspirationTimeline } from '@lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const entries = await getInspirationTimeline();

const minYear = entries.length > 0 ? Math.min(...entries.map((e) => e.date.getFullYear())) : null;
const stats = [
  `❖ ${pluralize(locale, entries.length, strings.stats.books)}`,
  ...(minYear ? [`${strings.stats.since} ${minYear}`] : []),
];
---

<BaseLayout locale={locale} title={strings.sections.inspiration.title} alternatePath="inspiration" ogImage={`/og/inspiration-${locale}.png`}>
  <section class="page-frame index">
    <SectionMasthead
      eyebrow="vol. 02"
      title={strings.sections.inspiration.title}
      lede={strings.sections.inspiration.lede}
      stats={stats}
    />
    {entries.length === 0 ? (
      <p class="empty">{strings.empty.inspiration}</p>
    ) : (
      <Timeline locale={locale} entries={entries} />
    )}
  </section>
</BaseLayout>

<style>
  .index {
    padding: 0 var(--space-3) var(--space-6);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
