{
  "name": "@yermilov/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@yermilov/api-types": "workspace:*",
    "@yermilov/db-schema": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.10",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.2"
  }
}
