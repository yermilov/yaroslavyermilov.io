---
export const prerender = true;
import { LOCALES, t, localePath, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTabs from '@components/SectionTabs.astro';
import Timeline from '@components/Timeline.astro';
import { getWritingTalkingTimeline } from '@lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const entries = (await getWritingTalkingTimeline(locale)).filter((e) => e.kind === 'talk');

const tabs = [
  { href: localePath(locale, 'writing-talking'), label: strings.subnav.all },
  { href: localePath(locale, 'writing-talking/writing'), label: strings.subnav.writing },
  { href: localePath(locale, 'writing-talking/talking'), label: strings.subnav.talking, active: true },
  { href: localePath(locale, 'writing-talking/kit'), label: strings.subnav.kit },
];
---

<BaseLayout locale={locale} title={`${strings.sections.writingTalking.title} — ${strings.subnav.talking}`} alternatePath="writing-talking/talking" ogImage={`/og/writing-talking-${locale}.png`}>
  <section class="page-frame index">
    <h1 class="sr-only">{strings.sections.writingTalking.title} — {strings.subnav.talking}</h1>
    <SectionTabs tabs={tabs} label={strings.sections.writingTalking.title} />
    {entries.length === 0 ? (
      <p class="empty">{strings.empty.talking}</p>
    ) : (
      <Timeline locale={locale} entries={entries} />
    )}
  </section>
</BaseLayout>

<style>
  .index {
    padding: var(--space-4) var(--space-3) var(--space-6);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
