---
import type { Locale } from '@lib/i18n';
import { t, localePath } from '@lib/i18n';
import LocaleSwitcher from './LocaleSwitcher.astro';
import Search from './Search.astro';

interface Props {
  locale: Locale;
  /** path within current locale where the alternate translation lives, e.g. "blog/foo" */
  alternatePath?: string | undefined;
  /** if true, the alternate locale has no equivalent of this page */
  alternateMissing?: boolean;
}

const { locale, alternatePath, alternateMissing = false } = Astro.props;
const strings = t(locale);
const homeHref = localePath(locale);

const navItems = [
  { href: localePath(locale, 'writing-talking'), label: strings.nav.writingTalking },
  { href: localePath(locale, 'inspiration'), label: strings.nav.inspiration },
  { href: localePath(locale, 'personal'), label: strings.nav.personal },
  { href: localePath(locale, 'workshop'), label: strings.nav.workshop },
  { href: localePath(locale, 'lab'), label: strings.nav.lab },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="page-frame header-row">
    <a class="brand" href={homeHref} aria-label={strings.nav.home}>
      <span class="brand-mark">{strings.nav.home}</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const active = currentPath === item.href || currentPath.startsWith(item.href);
            return (
              <li>
                <a href={item.href} class:list={['nav-link', { 'nav-link-active': active }]}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
        <li class="mobile-locale">
          <LocaleSwitcher
            locale={locale}
            alternatePath={alternatePath}
            alternateMissing={alternateMissing}
          />
        </li>
      </ul>
    </nav>
    <div class="header-end">
      <div class="search-slot"><Search locale={locale} /></div>
      <div class="desktop-locale">
        <LocaleSwitcher
          locale={locale}
          alternatePath={alternatePath}
          alternateMissing={alternateMissing}
        />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg-paper);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(140%) blur(6px);
  }
  .header-row {
    box-sizing: border-box;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    max-width: min(64rem, 100vw);
    padding: 0.5rem var(--space-3);
    width: 100%;
  }
  .brand {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--ink);
    border: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .brand:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .brand-mark {
    color: var(--green-primary);
    font-weight: 700;
    text-transform: lowercase;
  }
  nav {
    flex: 1 1 min(18rem, calc(100vw - 5rem));
    max-width: min(18rem, calc(100vw - 5rem));
    min-width: 0;
    overflow: visible;
  }
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
  }
  nav li {
    flex: 0 0 auto;
  }
  .mobile-locale {
    display: flex;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    border: none;
    padding: 4px 0;
    border-bottom: 1.5px solid transparent;
    white-space: nowrap;
  }
  .nav-link:hover {
    background: transparent;
    color: var(--orange-accent);
    border-bottom-color: var(--orange-accent);
  }
  .nav-link-active {
    color: var(--green-primary);
    border-bottom-color: var(--green-primary);
  }
  .header-end {
    display: none;
  }
  .search-slot {
    display: none;
  }
  @media (min-width: 768px) {
    .header-row {
      display: flex;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      flex-wrap: wrap;
    }
    .brand {
      align-self: auto;
    }
    nav {
      display: block;
      max-width: none;
      min-width: 0;
      overflow: visible;
    }
    nav ul {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
    }
    .nav-link {
      font-size: 0.85rem;
    }
    .mobile-locale {
      display: none;
    }
    .header-end {
      flex: 0 0 auto;
      display: flex;
      gap: var(--space-2);
      align-items: center;
      margin-left: auto;
    }
    .desktop-locale {
      display: block;
    }
    .search-slot {
      display: inline-block;
    }
  }
</style>
